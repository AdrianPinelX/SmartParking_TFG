<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Plaza sencilla -->
    <style name="PlazaSencilla">
        <item name="android:layout_width">@dimen/plaza_size</item>
        <item name="android:layout_height">@dimen/plaza_size</item>
        <item name="android:textSize">@dimen/plaza_text</item>
        <item name="android:background">@drawable/fondo_plaza</item>
        <item name="android:textColor">#000000</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">4dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Plaza discapacitado -->
    <style name="PlazaDiscapacitado">
        <item name="android:layout_width">@dimen/plaza_size</item>
        <item name="android:layout_height">@dimen/plaza_size</item>
