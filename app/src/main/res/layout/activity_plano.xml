<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:padding="16dp">

    <!-- Botón Volver -->
    <Button
        android:id="@+id/btnVolver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Volver"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D47A1"
        android:padding="10dp"
        android:minHeight="44dp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="16sp"
        android:autoSizeStepGranularity="1sp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Título -->
    <TextView
        android:id="@+id/txtTituloPlano"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plano del garaje"
        android:textColor="#0D47A1"
        android:textStyle="bold"
        android:textSize="26sp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="22sp"
        android:autoSizeMaxTextSize="26sp"
        android:autoSizeStepGranularity="1sp"

        app:layout_constraintTop_toBottomOf="@id/btnVolver"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Texto: Plantas -->
    <TextView
        android:id="@+id/txtTituloPlantas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plantas"
        android:textColor="#0D47A1"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="16dp"

        app:layout_constraintTop_toBottomOf="@id/txtTituloPlano"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Spinner de plantas -->
    <Spinner
        android:id="@+id/spinnerPlantas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"

        app:layout_constraintTop_toBottomOf="@id/txtTituloPlantas"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Leyenda -->
    <LinearLayout
        android:id="@+id/layoutLeyenda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginTop="16dp"

        app:layout_constraintTop_toBottomOf="@id/txtTituloPlano"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leyenda"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟦 Discapacitado"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟩 Eléctrico"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬜ Sencilla"
            android:textSize="15sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟥 Ocupada"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Imagen del plano -->
    <ImageView
        android:id="@+id/imagePlano"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:src="@drawable/planta1"

        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"

        app:layout_constraintTop_toBottomOf="@id/spinnerPlantas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/txtIndicacionPlaza"/>

    <!-- Texto: Seleccione la plaza mirando el plano -->
    <TextView
        android:id="@+id/txtIndicacionPlaza"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccione la plaza mirando el plano"
        android:textColor="#0D47A1"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"

        app:layout_constraintTop_toBottomOf="@id/imagePlano"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Spinner de plazas -->
    <Spinner
        android:id="@+id/spinnerPlazas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        app:layout_constraintTop_toBottomOf="@id/txtIndicacionPlaza"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón Continuar -->
    <Button
        android:id="@+id/btnContinuar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Continuar"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D47A1"
        android:padding="12dp"
        android:minHeight="52dp"
        android:textSize="20sp"
        android:textStyle="bold"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="16sp"
        android:autoSizeMaxTextSize="20sp"
        android:autoSizeStepGranularity="1sp"

        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"

        app:layout_constraintTop_toBottomOf="@id/spinnerPlazas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>