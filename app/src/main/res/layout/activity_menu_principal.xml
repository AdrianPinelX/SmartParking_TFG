<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- Título con autosize suave -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menú principal"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:textSize="26sp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="22sp"
        android:autoSizeMaxTextSize="26sp"
        android:autoSizeStepGranularity="1sp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Botón Realizar reserva -->
    <Button
        android:id="@+id/btnHacerReserva"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="172dp"
        android:backgroundTint="#3949AB"
        android:drawableLeft="@drawable/ic_reserva"
        android:drawablePadding="12dp"
        android:padding="16dp"
        android:text="Realizar reserva"
        android:textColor="#FFFFFF"
        android:textSize="18sp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="16sp"
        android:autoSizeMaxTextSize="18sp"
        android:autoSizeStepGranularity="1sp"

        android:minHeight="52dp"

        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Botón Mis reservas -->
    <Button
        android:id="@+id/btnMisReservas"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Reservas guardadas"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1E88E5"
        android:padding="16dp"
        android:drawableLeft="@drawable/ic_mis_reservas"
        android:drawablePadding="12dp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="16sp"
        android:autoSizeMaxTextSize="18sp"
        android:autoSizeStepGranularity="1sp"

        android:minHeight="52dp"

        app:layout_constraintTop_toBottomOf="@id/btnHacerReserva"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Botón Cerrar sesión -->
    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Cerrar sesión"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:padding="12dp"

        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeMaxTextSize="16sp"
        android:autoSizeStepGranularity="1sp"

        android:minHeight="48dp"

        app:layout_constraintTop_toBottomOf="@id/btnMisReservas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>